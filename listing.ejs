<div class="commit-log">
  <div class="logbar"><span class="prompt">$</span> git log --posts<span class="cmt">  // recent field notes</span></div>
<% for (const item of items) {
     // date → YYYY-MM-DD (hash-like)
     let ds = '';
     if (item.date) { try { ds = new Date(item.date).toISOString().slice(0, 10); } catch (e) { ds = String(item.date); } }
     // categories → labels
     const cats = item.categories || [];
     // commit "type": explicit front-matter `type`, else inferred from categories
     let tp = item.type;
     if (!tp) {
       const lc = cats.map(function (c) { return String(c).toLowerCase(); });
       if (lc.some(function (c) { return ['ai', 'ml', 'machine-learning', 'machine learning'].indexOf(c) >= 0; })) tp = 'ml';
       else if (lc.some(function (c) { return ['analytics', 'ga4', 'data'].indexOf(c) >= 0; })) tp = 'data';
       else tp = 'feat';
     }
%>
  <a class="commit" href="<%- item.path %>">
    <span class="graph">&#9679;</span>
    <span class="hash"><%= ds %></span>
    <span class="tt <%= tp %>"><%= tp %></span>
    <span class="ctitle"><%= item.title %></span>
    <span class="clabels"><% cats.forEach(function (c) { %><span class="lbl"><%= c %></span><% }); %></span>
  </a>
<% } %>
</div>
