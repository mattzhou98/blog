# Quarto build artifacts — these are generated, never commit them.
/_site/
/.quarto/

# Quarto computational cache. This is a Markdown-only blog (no executable code),
# so _freeze is never produced and is safe to ignore. NOTE: if you ever add
# executable R/Python/Julia code with `execute: freeze: auto`, REMOVE this line
# and commit /_freeze/ so CI doesn't need a language runtime to render.
/_freeze/

# OS / editor cruft
.DS_Store
Thumbs.db
*.tmp
.vscode/

**/*.quarto_ipynb
