---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import GradientDescent from '../components/GradientDescent.tsx';
import { u } from '../lib/paths';

// Posts, newest first, for the "recent" listing below.
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<BaseLayout title="matthew.zhou — Field Notes">
  <section class="hero">
    <aside class="island" style="flex:0 0 300px;align-self:flex-start;margin:0">
      <p class="k">whoami</p>
      <div style="display:flex;gap:.8rem;align-items:center;margin-bottom:.75rem">
        <img src={u('profile.jpg')} alt="Matthew Zhou" width="64" height="64"
             style="border-radius:12px;object-fit:cover;border:1px solid var(--fn-line);flex:0 0 auto" />
        <div style="min-width:0">
          <div style="font-family:var(--fn-display);font-weight:700;font-size:1.05rem;letter-spacing:-.01em">Matthew Zhou</div>
        </div>
      </div>
      <p style="margin:0;font-size:.82rem;line-height:1.55;color:var(--fn-ink)">Master of Applied Data Science student at the University of Michigan with a BS in Computer Science. I build machine learning pipelines and data processing systems in Python and C++.</p>
    </aside>
    <div class="hero-main">
      <p class="tag3"><span class="c">code</span><span class="x">×</span><span class="d">data</span><span class="x">×</span><span class="a">AI</span></p>
      <h1 class="hero-title">Field&nbsp;Notes</h1>
      <p class="hero-sub">Just another dev blog.</p>
    </div>
  </section>

  <p class="section-label">recent</p>
  <div class="commit-log">
    <div class="logbar"><span class="prompt">$</span> git log --posts <span class="cmt">// recent field notes</span></div>
    {posts.map((p) => (
      <a class="commit" href={u(`posts/${p.id}/`)}>
        <span class="graph">&#9679;</span>
        <span class="hash">{p.data.date.toISOString().slice(0, 10)}</span>
        <span class={`tt ${p.data.type}`}>{p.data.type}</span>
        <span class="ctitle">{p.data.title}</span>
        <span class="clabels">{p.data.categories.map((c) => <span class="lbl">{c}</span>)}</span>
      </a>
    ))}
  </div>
  <p class="section-label">For those who want something to play with</p>
  <GradientDescent client:visible />
</BaseLayout>
