---
import BaseLayout from '../layouts/BaseLayout.astro';
import Showcase from '../showcase.mdx';
// /lab is a living reference of everything usable in a post — the content lives
// in src/showcase.mdx so it goes through the exact same MDX pipeline a real post
// does (cross-refs, KaTeX, code highlighting, islands).
---
<BaseLayout title="Lab — matthew.zhou" description="Everything you can put in a post: components, math, diagrams, cross-references, and the design system — with copy-paste MDX.">
  <div class="prose">
    <Showcase />
  </div>
</BaseLayout>
